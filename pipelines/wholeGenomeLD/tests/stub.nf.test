
nextflow_pipeline {

    name "Whole Genome LDZip Stub Test Pipeline"
    script "main.nf"
    options "-stub"

    test("Should run without failures - PLINK") {

        when {
            params {
                load("$projectDir/tests/yaml/stub.yaml")
                outdir = "$projectDir/.nf-test"
            }
        }

        then {
            assert workflow.success
        }

    }

    test("Should run without failures - NPZ") {

        when {
            params {
                load("$projectDir/tests/yaml/stub.npz.yaml")
                outdir = "$projectDir/.nf-test-npz"
            }
        }

        then {
            assert workflow.success
        }

    }

}